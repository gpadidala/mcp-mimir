# === Prometheus Connection ===
PROMETHEUS_URL=http://host.docker.internal:9090

# === Org / Multi-Tenancy (Mimir, Cortex, Thanos) ===
# Set this to your default org/tenant ID
# This gets sent as X-Scope-OrgID header to Prometheus/Mimir
PROMETHEUS_ORGID=

# === Authentication (uncomment one method) ===
# Basic auth
# PROMETHEUS_USERNAME=myuser
# PROMETHEUS_PASSWORD=mypassword
# Bearer token
# PROMETHEUS_TOKEN=my-bearer-token

# === Transport ===
TRANSPORT=sse
HTTP_ADDR=:8080
METRICS_ADDR=:9091

# === Host port mapping ===
MCP_PORT=8080
METRICS_PORT=9091
